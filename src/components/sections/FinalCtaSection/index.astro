---
import styles from "./FinalCtaSection.module.scss";

interface Props {
  whatsappLink: string;
}

const { whatsappLink } = Astro.props;
---

<section class={styles.section} id="contato">
  <div class:list={[styles.panel, "reveal"]}>
    <div class={styles.content}>
      <div class={styles.metaLine}>
        <span class={styles.metaBadge}>Seção 07</span>
        <span class={styles.metaDate}>Avaliação gratuita</span>
      </div>
      <h2>Agende sua avaliação gratuita e descubra o plano certo para o seu objetivo.</h2>
      <p>
        Escolha o melhor canal para falar com o Lucas e dar o primeiro passo com
        acompanhamento profissional.
      </p>

      <div class={styles.actions}>
        <a class:list={[styles.button, styles.buttonPrimary]} href={whatsappLink} target="_blank" rel="noreferrer">
          Falar no WhatsApp
        </a>
      </div>
    </div>

    <form class={styles.form} action="mailto:contato@lucasforte.com" method="post" enctype="text/plain">
      <label>
        Nome
        <input type="text" name="name" placeholder="Seu nome" />
      </label>
      <label>
        WhatsApp
        <input type="tel" name="phone" placeholder="(11) 99999-9999" />
      </label>
      <label>
        Objetivo
        <input type="text" name="goal" placeholder="Emagrecer ou ganhar massa" />
      </label>
      <p class={styles.note}>
        Ou preencha o formulário para receber o contato com a avaliação inicial.
      </p>
      <button class:list={[styles.button, styles.buttonPrimary]} type="submit">Agende sua avaliação gratuita</button>
    </form>
  </div>
</section>
