---
import styles from "./FinalCtaSection.module.scss";

interface Props {
  whatsappLink: string;
}

const { whatsappLink } = Astro.props;
---

<section class={styles.section} id="contato">
  <div class={styles.shell}>
    <div class:list={[styles.panel, "reveal"]}>
      <div class={styles.content}>
        <div class={styles.metaLine}>
          <span class={styles.metaBadge}>Seção 07</span>
        </div>
        <h2>Agende sua avaliação gratuita e descubra o plano certo para o seu objetivo.</h2>
      </div>

      <form class={styles.form} action="mailto:contato@lucasforte.com" method="post" enctype="text/plain">
        <label>
          Nome
          <input type="text" name="name" placeholder="Seu nome" />
        </label>
        <label>
          WhatsApp
          <input type="tel" name="phone" placeholder="(11) 99999-9999" />
        </label>
        <label>
          Objetivo
          <input type="text" name="goal" placeholder="Emagrecer ou ganhar massa" />
        </label>
        <button class:list={[styles.button, styles.buttonPrimary]} type="submit" data-magnetic data-cursor="inverse">Agende sua avaliação gratuita</button>
      </form>
    </div>

    <footer class:list={[styles.footer, "reveal"]}>
      <div class={styles.brandBlock}>
        <span class={styles.brandEyebrow}>Lucas Forte Personal</span>
        <strong>Treino presencial e online com método, constância e resultado.</strong>
      </div>

      <nav class={styles.footerNav} aria-label="Navegação do rodapé">
        <a href="#topo">Início</a>
        <a href="#contato">Contato</a>
        <a href={whatsappLink} target="_blank" rel="noreferrer">WhatsApp</a>
      </nav>

      <div class={styles.footerMeta}>
        <span>São Paulo / SP</span>
        <span>CREF fictício 00/000000-G/SP</span>
      </div>
    </footer>
  </div>
</section>
