---
import { about } from "../../../data/about";
import styles from "./AboutSection.module.scss";
---

<section class={styles.section}>
  <div class={styles.container}>
    <div class={styles.stageWord} aria-hidden="true">profile</div>

    <div class={styles.layout}>
      <div class:list={[styles.profilePanel, "reveal"]}>
        <div class={styles.photoMeta}>
          <span class={styles.metaBadge}>Seção 06</span>
        </div>

        <div class={styles.photoFrame}>
          <div class={styles.photo}>
            <img
              src="https://images.unsplash.com/photo-1567013127542-490d757e51fc?auto=format&fit=crop&w=720&q=74"
              srcset="https://images.unsplash.com/photo-1567013127542-490d757e51fc?auto=format&fit=crop&w=480&q=72 480w, https://images.unsplash.com/photo-1567013127542-490d757e51fc?auto=format&fit=crop&w=720&q=74 720w, https://images.unsplash.com/photo-1567013127542-490d757e51fc?auto=format&fit=crop&w=900&q=76 900w"
              sizes="(max-width: 960px) 100vw, 45vw"
              alt="Lucas Forte em treino funcional"
              width="900"
              height="1200"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>

      <div class:list={[styles.content, "reveal"]}>
        <div class={styles.headerBlock}>
          <h2>{about.title}</h2>
        </div>

        <div class={styles.copy}>
          {about.description.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>

        <div class={styles.credentialsPanel}>
          <div class={styles.credentials}>
            {about.credentials.map((credential, index) => (
              <div class={styles.credentialItem}>
                <span>0{index + 1}</span>
                <p>{credential}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
