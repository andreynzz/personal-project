---
import styles from "./HeroSection.module.scss";
import { heroTickerItems } from "../../../data/heroTickerItems";

interface Props {
  whatsappLink: string;
}

const { whatsappLink } = Astro.props;
---

<section class={styles.section}>
  <div class={styles.ticker}>
    <div class={styles.tickerInner}>
      {[...heroTickerItems, ...heroTickerItems].map((item) => (
        <span class={styles.tickerItem}>
          {item}
          <span class={styles.tickerSep}>·</span>
        </span>
      ))}
    </div>
  </div>

  <div class={styles.wrapper}>
    <div class={styles.sidebar}>
      <span class={styles.sidebarLabel}>Lucas Forte Personal</span>
      <span class={styles.sidebarNum}>01</span>
    </div>

    <div class={styles.main}>
      <div class:list={[styles.content, "reveal"]}>
        <div class={styles.metaLine}>
          <span class={styles.metaBadge}>Presencial & Online</span>
          <span class={styles.metaDate}>São Paulo — Performance Training</span>
        </div>

        <h1 class={styles.headline}>
          <span class={styles.headlineOutline}>Transforme</span>
          <span>
            <span class={styles.headlineHalf}>seu</span>
            <span class={styles.headlineFill}>físico</span>
          </span>
          <span class={styles.headlineAccent}>de vez.</span>
        </h1>

        <div class={styles.pullQuote}>
          <p>
            Personal trainer para adultos de 25 a 40 anos que querem emagrecer,
            ganhar massa e finalmente manter resultado com estratégia,
            constância e acompanhamento individual.
          </p>
        </div>

        <div class={styles.actions}>
          <a class:list={[styles.button, styles.buttonPrimary]} href={whatsappLink} target="_blank" rel="noreferrer">
            Quero começar agora
          </a>
          <a class:list={[styles.button, styles.buttonGhost]} href="#contato">Agendar avaliação</a>
        </div>

        <p class={styles.proof}><span>+120 alunos</span> acompanhados · emagrecimento · hipertrofia</p>
      </div>

    </div>

    <div class:list={[styles.visual, "reveal"]}>
      <div class={styles.photoCard}>
        <img
          src="https://images.unsplash.com/photo-1517836357463-d25dfeac3438?auto=format&fit=crop&w=1200&q=80"
          alt="Personal trainer em pose de treino"
          loading="eager"
        />
        <div class={styles.overlay}></div>
        <div class={styles.photoTop}>
          <div class={styles.tagBox}>
            <span>Entre em contato</span>
          </div>
        </div>
        <div class={styles.statsGrid}>
          <div class:list={[styles.statCell, styles.statCellAccent]}>
            <strong>+120</strong>
            <span>alunos acompanhados</span>
          </div>
          <div class={styles.statCell}>
            <strong>12sem</strong>
            <span>resultado visível</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
