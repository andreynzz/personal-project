---
import styles from "./HeroSection.module.scss";
import { heroTickerItems } from "../../../data/heroTickerItems";
import HeroExperience from "../../ui/HeroExperience/index";

interface Props {
  whatsappLink: string;
}

const { whatsappLink } = Astro.props;
---

<section class={styles.section} data-hero-root id="topo">
  <HeroExperience client:media="(min-width: 961px)" />
  <div class={styles.ticker}>
    <div class={styles.tickerInner} data-hero-ticker>
      {[...heroTickerItems, ...heroTickerItems].map((item) => (
        <span class={styles.tickerItem}>
          {item}
          <span class={styles.tickerSep}>·</span>
        </span>
      ))}
    </div>
  </div>

  <header class={styles.headerBar}>
    <span class={styles.headerBrand}>Lucas Forte Personal</span>
    <a
      class={styles.headerContact}
      href={whatsappLink}
      target="_blank"
      rel="noreferrer"
      data-magnetic
      data-cursor="inverse"
    >
      Entre em contato
    </a>
  </header>

  <div class={styles.wrapper}>
    <div class={styles.sidebar}>
      <span class={styles.sidebarLabel}>Lucas Forte Personal</span>
      <span class={styles.sidebarNum}>01</span>
    </div>

    <div class={styles.main}>
      <div class={styles.content} data-hero-content>
        <div class={styles.metaLine} data-hero-meta>
          <span class={styles.metaBadge}>Presencial & Online</span>
        </div>

        <h1 class={styles.headline} data-hero-headline>
          <span class={styles.headlineOutline} data-hero-line>Transforme</span>
          <span data-hero-line>
            <span class={styles.headlineHalf}>seu </span>
            <span class={styles.headlineFill}>físico</span>
          </span>
          <span class={styles.headlineAccent} data-hero-line>de vez.</span>
        </h1>

        <div class={styles.pullQuote} data-hero-copy>
          <p>
            Personal trainer para adultos de 25 a 40 anos que querem emagrecer,
            ganhar massa e finalmente manter resultado com estratégia,
            constância e acompanhamento individual.
          </p>
        </div>

        <div class={styles.actions} data-hero-actions>
          <a class:list={[styles.button, styles.buttonPrimary]} href={whatsappLink} target="_blank" rel="noreferrer" data-magnetic data-cursor="inverse">
            Quero começar agora
          </a>
          <a class:list={[styles.button, styles.buttonGhost]} href="#contato" data-magnetic data-cursor="inverse">Agendar avaliação</a>
        </div>
      </div>

    </div>

    <div class={styles.visual} data-hero-visual>
      <span class={styles.glowBlobPrimary} data-hero-glow></span>
      <span class={styles.glowBlobSecondary} data-hero-glow></span>
      <div class={styles.photoCard} data-hero-photo-card>
        <span class={styles.photoReveal} data-hero-reveal></span>
        <img
          data-hero-image
          src="https://images.unsplash.com/photo-1517836357463-d25dfeac3438?auto=format&fit=crop&w=960&q=72"
          srcset="https://images.unsplash.com/photo-1517836357463-d25dfeac3438?auto=format&fit=crop&w=640&q=72 640w, https://images.unsplash.com/photo-1517836357463-d25dfeac3438?auto=format&fit=crop&w=960&q=72 960w, https://images.unsplash.com/photo-1517836357463-d25dfeac3438?auto=format&fit=crop&w=1200&q=76 1200w"
          sizes="(max-width: 960px) 100vw, 50vw"
          alt="Personal trainer em pose de treino"
          width="1200"
          height="1600"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
        <div class={styles.overlay}></div>
      </div>
    </div>
  </div>
</section>
