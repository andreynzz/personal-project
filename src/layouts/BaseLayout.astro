---
import "../styles/global.scss";
import CustomCursor from "../components/ui/CustomCursor/index";
import SmoothScroll from "../components/ui/SmoothScroll/index";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Lucas Forte Personal | Treino presencial e online",
  description = "Landing page de portfólio para personal trainer focado em emagrecimento, hipertrofia e conversão via WhatsApp."
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <SmoothScroll client:load />
    <CustomCursor client:load />
    <slot />
  </body>
</html>
